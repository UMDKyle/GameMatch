# Copy this file to .env.local before running the project locally.
# No variables are required to run the app — it works fully without any keys.

# ── IGDB game data fetcher (fetchGames.js) ────────────────────────────────────
# Only needed when refreshing data/games.json locally.
# Register at https://dev.twitch.tv/console → create an app → copy credentials.
# IGDB_CLIENT_ID=
# IGDB_CLIENT_SECRET=

# ── OpenAI tag extraction (optional) ─────────────────────────────────────────
# AI-assisted tag extraction is disabled by default.
# Public deployments can leave both vars unset for zero OpenAI cost.
# To enable: set ENABLE_OPENAI_TAGS=true and provide a valid API key.
# The app falls back to the local keyword extractor if AI is off or fails.
# ENABLE_OPENAI_TAGS=false
# OPENAI_API_KEY=sk-...
