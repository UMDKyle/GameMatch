# Copy this file to .env.local before running the project locally.
# No variables are required to run the current version of the app.

# ── IGDB game data fetcher (fetchGames.js) ────────────────────────────────────
# Register at https://dev.twitch.tv/console → create an app → copy credentials.
# IGDB_CLIENT_ID=
# IGDB_CLIENT_SECRET=

# ── Future: OpenAI integration ────────────────────────────────────────────────
# Used by the recommendation API route to generate richer results.
# Obtain a key at https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...
